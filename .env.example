# Local development (SQLite). Copy to .env and adjust.
DATABASE_URL="file:./dev.db"

# --- Supabase (used when migrating app data to Postgres) ---
# Pooled connection (app runtime). Use the Supabase "Transaction" pooler URL.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (Prisma migrations only).
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase Auth (client + server) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
