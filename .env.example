# Copy to .env and fill in from your Supabase project dashboard.

# --- Database (Prisma) ---
# Supabase: Database > Connect > ORMs / Prisma.
# DATABASE_URL = Transaction pooler (port 6543) — used by the app at runtime.
# DIRECT_URL   = Direct connection (port 5432) — used for Prisma migrations.
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase Auth / API (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL="https://PROJECTREF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
